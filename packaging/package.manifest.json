{
  "$schema": "../../gnustep-packager/schemas/gnustep-packager.schema.json",
  "schemaVersion": 1,
  "package": {
    "id": "org.objcmarkdown.MarkdownViewer",
    "name": "ObjcMarkdown",
    "displayName": "ObjcMarkdown",
    "version": "0.1.1-rc2",
    "manufacturer": "ObjcMarkdown",
    "summary": "GNUstep Markdown viewer packaged through gnustep-packager.",
    "license": "MIT",
    "homepage": "https://github.com/danjboyd/ObjcMarkdown"
  },
  "pipeline": {
    "workingDirectory": "..",
    "shell": {
      "kind": "pwsh",
      "bootstrapCommands": [],
      "environment": {}
    },
    "build": {
      "command": "./packaging/scripts/build-for-packager.ps1"
    },
    "stage": {
      "command": "./packaging/scripts/stage-for-packager.ps1 -StageRoot dist/gnustep-packager-stage",
      "outputRoot": "../dist/gnustep-packager-stage"
    }
  },
  "payload": {
    "layoutVersion": 1,
    "stageRoot": "../dist/gnustep-packager-stage",
    "appRoot": "app",
    "runtimeRoot": "clang64",
    "metadataRoot": "metadata",
    "resourceRoots": [
      "app/MarkdownViewer.app/Resources",
      "metadata/icons"
    ],
    "runtimeSeedPaths": [
      "clang64/bin/defaults.exe"
    ]
  },
  "launch": {
    "entryRelativePath": "app/MarkdownViewer.app/MarkdownViewer.exe",
    "workingDirectory": ".",
    "arguments": [],
    "pathPrepend": [
      "clang64/bin",
      "clang64/texlive/TinyTeX/bin/windows"
    ],
    "resourceRoots": [
      "metadata/icons"
    ],
    "env": {
      "GNUSTEP_PATHPREFIX_LIST": "{@runtimeRoot}",
      "GSTheme": {
        "value": "WinUITheme",
        "policy": "ifUnset"
      }
    }
  },
  "outputs": {
    "root": "../dist/gnustep-packager",
    "packageRoot": "../dist/gnustep-packager/packages",
    "logRoot": "../dist/gnustep-packager/logs",
    "tempRoot": "../dist/gnustep-packager/tmp",
    "validationRoot": "../dist/gnustep-packager/validation"
  },
  "validation": {
    "smoke": {
      "enabled": true,
      "kind": "staged-layout",
      "requiredPaths": [
        "metadata/docs/BundledLaTeXRuntime.txt",
        "metadata/icons/markdown_icon.ico",
        "metadata/icons/markdown_icon.png",
        "metadata/docs/BundledThemes.txt",
        "clang64/bin/defaults.exe",
        "app/MarkdownViewer.app/Resources/theme-github.toml",
        "clang64/lib/GNUstep/Themes/WinUXTheme.theme/WinUXTheme.dll",
        "clang64/lib/GNUstep/Themes/Win11Theme.theme/Win11Theme.dll",
        "clang64/lib/GNUstep/Themes/WinUITheme.theme/WinUITheme.dll",
        "clang64/texlive/TinyTeX/bin/windows/latex.exe",
        "clang64/texlive/TinyTeX/bin/windows/dvisvgm.exe",
        "clang64/texlive/TinyTeX/bin/windows/dvipng.exe"
      ],
      "timeoutSeconds": 30
    },
    "logs": {
      "retainOnSuccess": true
    }
  },
  "integrations": {
    "shortcutName": "Markdown Viewer",
    "categories": [
      "Office",
      "TextEditor",
      "Utility"
    ],
    "fileAssociations": [
      {
        "kind": "extension",
        "value": ".md",
        "description": "Markdown document"
      },
      {
        "kind": "extension",
        "value": ".markdown",
        "description": "Markdown document"
      },
      {
        "kind": "extension",
        "value": ".mdown",
        "description": "Markdown document"
      }
    ]
  },
  "backends": {
    "msi": {
      "enabled": true,
      "upgradeCode": "ca1cb9b9-e6d5-41fd-bc64-a1782423500e",
      "installScope": "perUser",
      "productName": "ObjcMarkdown",
      "shortcutName": "Markdown Viewer",
      "installDirectoryName": "ObjcMarkdown",
      "launcherFileName": "MarkdownViewer.exe",
      "iconRelativePath": "metadata/icons/markdown_icon.ico",
      "fallbackRuntimeRoot": "C:\\clang64"
    },
    "appimage": {
      "enabled": false,
      "desktopEntryName": "MarkdownViewer.desktop"
    }
  }
}
