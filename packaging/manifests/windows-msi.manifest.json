{
  "$schema": "../../../gnustep/gnustep-packager/schemas/gnustep-packager.schema.json",
  "schemaVersion": 1,
  "profiles": [
    "gnustep-gui",
    "gnustep-document-viewer"
  ],
  "package": {
    "id": "org.objcmarkdown.MarkdownViewer",
    "name": "ObjcMarkdown",
    "displayName": "Markdown Viewer",
    "version": "0.1.1-rc2",
    "manufacturer": "ObjcMarkdown",
    "summary": "GNUstep Markdown viewer packaged through gnustep-packager.",
    "license": "MIT",
    "homepage": "https://github.com/danjboyd/ObjcMarkdown"
  },
  "pipeline": {
    "workingDirectory": "../..",
    "shell": {
      "kind": "pwsh",
      "msysRoot": "D:\\a\\_temp\\gnustep-cli-new",
      "bootstrapCommands": [],
      "environment": {}
    },
    "build": {
      "command": "./packaging/scripts/build-windows.ps1"
    },
    "stage": {
      "command": "./packaging/scripts/stage-windows.ps1 -StageRoot dist/packaging/windows/stage",
      "outputRoot": "../../dist/packaging/windows/stage"
    }
  },
  "hostDependencies": {
    "windows": {
      "msys2Packages": [
        "mingw-w64-clang-x86_64-cmark"
      ]
    }
  },
  "themeInputs": [
    {
      "name": "WinUITheme",
      "repo": "https://github.com/danjboyd/plugins-themes-winuitheme.git",
      "ref": "48d21f0a2ae97ca70a03197d93a305144635517f",
      "platforms": [
        "windows",
        "msi"
      ],
      "required": true,
      "default": true,
      "workspacePath": "../../.omd-theme-inputs/plugins-themes-winuitheme",
      "build": {
        "installCommand": "make install GNUSTEP_INSTALLATION_DOMAIN=USER; for theme_resources in WinUITheme.theme/Resources \"$GNUSTEP_HOME/GNUstep/Library/Themes/WinUITheme.theme/Resources\"; do if [ -d Resources/ThemeImages ] && [ -d \"$theme_resources\" ]; then cp Resources/ThemeImages/*.png \"$theme_resources\"/; fi; done",
        "environment": {
          "ADDITIONAL_CPPFLAGS": "-DHAVE_MODE_T=1",
          "ADDITIONAL_OBJCFLAGS": "-DHAVE_MODE_T=1"
        }
      }
    },
    {
      "name": "Win11Theme",
      "repo": "https://github.com/danjboyd/plugins-themes-win11theme.git",
      "ref": "390db8f",
      "platforms": [
        "windows",
        "msi"
      ],
      "required": false,
      "default": false,
      "workspacePath": "../../.omd-theme-inputs/plugins-themes-win11theme",
      "build": {
        "installCommand": "make install GNUSTEP_INSTALLATION_DOMAIN=USER; for theme_resources in Win11Theme.theme/Resources \"$GNUSTEP_HOME/GNUstep/Library/Themes/Win11Theme.theme/Resources\"; do if [ -d Resources/ThemeImages ] && [ -d \"$theme_resources\" ]; then cp Resources/ThemeImages/*.png \"$theme_resources\"/; fi; done",
        "environment": {
          "ADDITIONAL_CPPFLAGS": "-DHAVE_MODE_T=1",
          "ADDITIONAL_OBJCFLAGS": "-DHAVE_MODE_T=1"
        }
      }
    }
  ],
  "packagedDefaults": {
    "defaultTheme": "WinUITheme"
  },
  "payload": {
    "layoutVersion": 1,
    "stageRoot": "../../dist/packaging/windows/stage",
    "appRoot": "app",
    "runtimeRoot": "runtime",
    "metadataRoot": "metadata",
    "resourceRoots": [
      "metadata/icons"
    ],
    "runtimeSeedPaths": [
      "runtime/bin/defaults.exe"
    ]
  },
  "launch": {
    "entryRelativePath": "app/MarkdownViewer.app/MarkdownViewer.exe",
    "workingDirectory": ".",
    "arguments": [],
    "pathPrepend": [
      "runtime/bin",
      "runtime/texlive/TinyTeX/bin/windows"
    ],
    "resourceRoots": [
      "metadata/icons"
    ],
    "env": {
      "GNUSTEP_PATHPREFIX_LIST": "{@runtimeRoot}",
      "GSTheme": {
        "value": "WinUITheme",
        "policy": "ifUnset"
      }
    }
  },
  "outputs": {
    "root": "../../dist/packaging/windows",
    "packageRoot": "../../dist/packaging/windows/packages",
    "logRoot": "../../dist/packaging/windows/logs",
    "tempRoot": "../../dist/packaging/windows/tmp",
    "validationRoot": "../../dist/packaging/windows/validation"
  },
  "updates": {
    "enabled": true,
    "provider": "github-release-feed",
    "channel": "stable",
    "minimumCheckIntervalHours": 24,
    "startupDelaySeconds": 15,
    "github": {
      "owner": "danjboyd",
      "repo": "ObjcMarkdown",
      "tagPattern": "v{version}",
      "releaseNotesUrlPattern": "https://github.com/{owner}/{repo}/releases/tag/{tag}"
    }
  },
  "validation": {
    "smoke": {
      "enabled": true,
      "kind": "staged-layout",
      "requiredPaths": [
        "app/MarkdownViewer.app/gp-update-helper.exe",
        "app/MarkdownViewer.app/Resources/theme-github.toml",
        "metadata/icons/markdown_icon.ico",
        "metadata/icons/markdown_icon.png",
        "metadata/docs/BundledThemes.txt",
        "metadata/docs/BundledLaTeXRuntime.txt",
        "runtime/bin/defaults.exe",
        "runtime/bin/libcairo-2.dll",
        "runtime/bin/libfontconfig-1.dll",
        "runtime/bin/libfreetype-6.dll",
        "runtime/lib/GNUstep/Bundles/libgnustep-back-032.bundle/libgnustep-back-032.dll",
        "runtime/lib/GNUstep/Themes/WinUITheme.theme/WinUITheme.dll",
        "runtime/texlive/TinyTeX/bin/windows/latex.exe",
        "runtime/texlive/TinyTeX/bin/windows/dvisvgm.exe",
        "runtime/texlive/TinyTeX/bin/windows/dvipng.exe"
      ],
      "timeoutSeconds": 30
    },
    "logs": {
      "retainOnSuccess": true
    }
  },
  "integrations": {
    "shortcutName": "Markdown Viewer",
    "categories": [
      "Office",
      "TextEditor",
      "Utility"
    ],
    "fileAssociations": [
      {
        "kind": "extension",
        "value": ".md",
        "description": "Markdown document"
      },
      {
        "kind": "extension",
        "value": ".markdown",
        "description": "Markdown document"
      },
      {
        "kind": "extension",
        "value": ".mdown",
        "description": "Markdown document"
      },
      {
        "kind": "extension",
        "value": ".rtf",
        "description": "Rich Text document"
      },
      {
        "kind": "extension",
        "value": ".docx",
        "description": "Word document"
      },
      {
        "kind": "extension",
        "value": ".odt",
        "description": "OpenDocument Text document"
      }
    ]
  },
  "backends": {
    "msi": {
      "enabled": true,
      "upgradeCode": "ca1cb9b9-e6d5-41fd-bc64-a1782423500e",
      "installScope": "perUser",
      "productName": "ObjcMarkdown",
      "shortcutName": "Markdown Viewer",
      "installDirectoryName": "ObjcMarkdown",
      "launcherFileName": "MarkdownViewer.exe",
      "iconRelativePath": "metadata/icons/markdown_icon.ico",
      "artifactNamePattern": "{name}-{version}-win64.msi",
      "portableArtifactNamePattern": "{name}-{version}-win64-portable.zip",
      "fallbackRuntimeRoot": "C:\\clang64",
      "unresolvedDependencyPolicy": "fail",
      "ignoredRuntimeDependencies": [
        "DWrite.dll",
        "gdiplus.dll",
        "MSIMG32.dll",
        "OPENGL32.dll",
        "USP10.dll",
        "WINHTTP.dll",
        "WINSPOOL.DRV",
        "WSOCK32.dll",
        "DNSAPI.dll",
        "IPHLPAPI.DLL"
      ],
      "updates": {
        "feedUrl": "https://danjboyd.github.io/ObjcMarkdown/updates/windows/stable.json"
      },
      "wix": {
        "toolRoot": "../../dist/packaging/windows/tools/wix"
      }
    },
    "appimage": {
      "enabled": false
    }
  }
}
